# ──────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/ithar_db?schema=public"

# ──────────────────────────────────────────────
# NEXT AUTH
# ──────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ──────────────────────────────────────────────
# STRIPE
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ──────────────────────────────────────────────
# RESEND (Email)
# ──────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="ITHAR <noreply@ithar.co>"
EMAIL_REPLY_TO="support@ithar.co"

# ──────────────────────────────────────────────
# UPLOADTHING (File Uploads)
# ──────────────────────────────────────────────
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="your-app-id"

# ──────────────────────────────────────────────
# SITE
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="ITHAR"

# ──────────────────────────────────────────────
# ADMIN
# ──────────────────────────────────────────────
ADMIN_EMAIL="admin@ithar.co"

# ──────────────────────────────────────────────
# SHIPPING (Optional — ShipStation / EasyPost)
# ──────────────────────────────────────────────
EASYPOST_API_KEY=""
